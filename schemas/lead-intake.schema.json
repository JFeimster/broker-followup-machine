{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://broker-followup-machine.local/schemas/lead-intake.schema.json",
  "title": "Lead Intake Payload",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "record_type",
    "workflow_id",
    "business_name",
    "contact_name",
    "source",
    "human_review_required",
    "safety_flags"
  ],
  "properties": {
    "record_type": {
      "type": "string",
      "const": "lead-intake"
    },
    "workflow_id": {
      "type": "string",
      "enum": [
        "new-lead",
        "missing-docs",
        "stalled-deal",
        "declined-reactivation",
        "funded-renewals",
        "referral-nurture",
        "dead-lead-revival"
      ]
    },
    "business_name": {
      "type": "string",
      "minLength": 1
    },
    "contact_name": {
      "type": "string",
      "minLength": 1
    },
    "contact_role": {
      "type": "string"
    },
    "contact_email": {
      "type": "string",
      "format": "email"
    },
    "contact_phone": {
      "type": "string"
    },
    "source": {
      "type": "string"
    },
    "requested_follow_up_channel": {
      "type": "string",
      "enum": [
        "email",
        "sms",
        "call",
        "voicemail"
      ]
    },
    "human_review_required": {
      "type": "boolean"
    },
    "safety_flags": {
      "$ref": "#/$defs/safetyFlags"
    },
    "notes": {
      "type": "string"
    }
  },
  "$defs": {
    "safetyFlags": {
      "type": "object",
      "additionalProperties": false,
      "required": [
        "lender_specific_statement",
        "underwriting_related_message",
        "decline_related_message",
        "sensitive_document_handling",
        "borrower_facing_claim"
      ],
      "properties": {
        "lender_specific_statement": {
          "type": "boolean"
        },
        "underwriting_related_message": {
          "type": "boolean"
        },
        "decline_related_message": {
          "type": "boolean"
        },
        "sensitive_document_handling": {
          "type": "boolean"
        },
        "borrower_facing_claim": {
          "type": "boolean"
        }
      }
    }
  }
}
