{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://broker-followup-machine.local/schemas/safety-review.schema.json",
  "title": "Safety Review",
  "type": "object",
  "additionalProperties": false,
  "required": [
    "review_id",
    "workflow_id",
    "review_scope",
    "risk_level",
    "human_review_required",
    "safety_flags"
  ],
  "properties": {
    "review_id": {
      "type": "string"
    },
    "workflow_id": {
      "type": "string",
      "enum": [
        "new-lead",
        "missing-docs",
        "stalled-deal",
        "declined-reactivation",
        "funded-renewals",
        "referral-nurture",
        "dead-lead-revival"
      ]
    },
    "review_scope": {
      "type": "string",
      "enum": [
        "draft",
        "send",
        "underwriting-related",
        "decline-related",
        "document-handling",
        "lender-specific",
        "borrower-facing-claim"
      ]
    },
    "risk_level": {
      "type": "string",
      "enum": [
        "low",
        "medium",
        "high"
      ]
    },
    "human_review_required": {
      "type": "boolean",
      "const": true
    },
    "safety_flags": {
      "$ref": "#/$defs/safetyFlags"
    },
    "reviewer_notes": {
      "type": "string"
    },
    "review_status": {
      "type": "string",
      "enum": [
        "needs-review",
        "reviewed",
        "blocked"
      ]
    }
  },
  "$defs": {
    "safetyFlags": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "lender_specific_statement": {
          "type": "boolean"
        },
        "underwriting_related_message": {
          "type": "boolean"
        },
        "decline_related_message": {
          "type": "boolean"
        },
        "sensitive_document_handling": {
          "type": "boolean"
        },
        "borrower_facing_claim": {
          "type": "boolean"
        }
      }
    }
  }
}
